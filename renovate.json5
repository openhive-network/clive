{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["local>hive/common-ci-configuration//renovate/python.json5"],

  // Clive uses unlimited concurrent PRs
  "prConcurrentLimit": 0,

  "packageRules": [
    {
      "description": "Textual ecosystem (TUI framework)",
      "groupName": "textual",
      "matchPackageNames": ["textual", "textual-dev"]
    },
    {
      "description": "Typer ecosystem (CLI framework)",
      "groupName": "typer",
      "matchPackageNames": ["/^typer/"]
    }
  ]
}
